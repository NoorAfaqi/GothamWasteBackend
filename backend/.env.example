PORT=3000

# Realtime Database URL (Firebase Console → Realtime Database)
FIREBASE_DATABASE_URL=

# --- Firebase Admin credentials (pick ONE approach) ---

# A) Entire service account JSON on one line (escape inner double quotes), or use BASE64 below
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# B) Base64-encoded JSON file contents (good for serverless)
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# C) Same fields as the downloaded JSON, with FIREBASE_SA_ prefix (recommended for .env)
FIREBASE_SA_TYPE=service_account
FIREBASE_SA_PROJECT_ID=
FIREBASE_SA_PRIVATE_KEY_ID=
# Use literal \n for newlines inside the key, in double quotes:
# FIREBASE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n"
FIREBASE_SA_PRIVATE_KEY=
FIREBASE_SA_CLIENT_EMAIL=
FIREBASE_SA_CLIENT_ID=
FIREBASE_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_SA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_SA_CLIENT_X509_CERT_URL=
FIREBASE_SA_UNIVERSE_DOMAIN=googleapis.com

# D) Path to JSON file (optional fallback)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Optional: reuse project id for SA if FIREBASE_SA_PROJECT_ID omitted
# FIREBASE_PROJECT_ID=

FIREBASE_WRITE_TIMEOUT_MS=30000
